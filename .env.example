# =====================================================================
# ENTERPRISE WEB AUTOMATION FRAMEWORK - TEMPLATE CONFIGURATION
# =====================================================================
# INSTRUCTIONS:
# 1. Copy this file to '.env'
# 2. Add your private API keys and configuration
# 3. DO NOT commit your '.env' file to version control
# =====================================================================

# API CONFIGURATION
# Get your API keys from:
# Gemini: https://aistudio.google.com/app/apikey
# Groq: https://console.groq.com/keys
# OpenAI: https://platform.openai.com/api-keys (optional)

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
VISION_MODEL=gemini-2.0-flash
COMPUTER_USE_MODEL=gemini-2.5-computer-use-preview-10-2025
API_TIMEOUT=30

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

OPENAI_API_KEY=your_openai_api_key_here

# BROWSER CONFIGURATION
HEADLESS=false
BROWSER_TYPE=chrome
DISABLE_GPU=false
NO_SANDBOX=false
DISABLE_DEV_SHM=false

# Browser Window & Viewport
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# Chrome Executable Path
# Example Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Example Linux: /usr/bin/google-chrome
CHROME_EXECUTABLE_PATH=

# PROXY CONFIGURATION
USE_PROXY=false
PROXY_URL=http://proxy.example.com:8080
ROTATE_PROXY=false

# ANTI-BOT EVASION
ANTI_BOT_ENABLED=true
ENABLE_STEALTH=true
RANDOM_DELAY=true
USER_AGENT_ROTATION=true
RANDOMIZE_HEADERS=true
DELAY_RANGE_MIN=1.5
DELAY_RANGE_MAX=4.5
TYPING_DELAY_MIN=0.05
TYPING_DELAY_MAX=0.15

# DATABASE
DATABASE_URL=sqlite:///automation.db
DB_ECHO=false

# LOGGING
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=automation.log
LOG_FORMAT=detailed

# SCREENSHOTS
SCREENSHOTS_ENABLED=true
SCREENSHOT_DIR=screenshots
FULL_PAGE_SCREENSHOTS=true
SCREENSHOT_FORMAT=png

# TIMEOUTS (seconds)
PAGE_LOAD_TIMEOUT=90
ELEMENT_WAIT_TIMEOUT=15
ACTION_DELAY_MIN=0.8
ACTION_DELAY_MAX=2.5

# TARGET URL (fallback only)
TARGET_URL=https://demoqa.com/

# ENVIRONMENT
ENVIRONMENT=development
DEBUG=false
